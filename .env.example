OPENAI_API_KEY=your_key_here
OPENAI_MODEL=gpt-4o-mini

# Tesseract (only needed if not on PATH)
TESSERACT_CMD=C:/Program Files/Tesseract-OCR/tesseract.exe

# PDF2Image poppler bin path (only needed if not on PATH)
POPPLER_PATH=C:/path/to/poppler/Library/bin

# Output language for OCR
OCR_LANG=eng

# Shared secret Anurag's Node backend sends in the X-Internal-Key header.
# Empty = open (dev). Set the SAME value here and in Node's env before deploy.
INTERNAL_API_KEY=

# true = AI endpoints return canned JSON without calling OpenAI (demo/no-cost).
SIMULATION_MODE=false
